rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { 
      // For this app, we'll allow anyone who knows the admin password in the mock, 
      // but in Firestore we should ideally have an 'admins' collection or check user role.
      // Since users are stored in 'users' collection, let's use that.
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'ADMIN';
    }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // Users Collection
    match /users/{userId} {
      // For this app's simplified auth (id-based), we'll allow public creation 
      // but usually this would be restricted. 
      // Actually, since the app allows registering locally, we'll allow it.
      allow read: if true; // Everyone can see member list in this small app context
      allow create: if true; // Public registration
      allow update: if true; // Allow voting updates and status updates for now
    }

    // Candidates Collection
    match /candidates/{candidateId} {
      allow read: if true; // Public view
      allow create: if true; // Public application (voter portal)
      allow update: if true; // Admin approval or votes increment
    }

    // Config Collection
    match /config/election {
      allow read: if true;
      allow write: if true; // Admin settings
    }
  }
}
